<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <!-- Ordre de compilation important en F# : du plus bas niveau au plus haut. -->
  <ItemGroup>
    <Compile Include="Domain.fs" />
    <Compile Include="I18n.fs" />
    <Compile Include="Contenu.fs" />
    <Compile Include="Storage.fs" />
    <Compile Include="State.fs" />
    <Compile Include="View.fs" />
    <Compile Include="Main.fs" />
  </ItemGroup>

  <!-- Versions indicatives : compilées par Fable 5. Ajuste si besoin. -->
  <ItemGroup>
    <PackageReference Include="Fable.Core" Version="5.0.0" />
    <PackageReference Include="Fable.Elmish" Version="5.0.2" />
    <PackageReference Include="Fable.Elmish.React" Version="5.6.0" />
    <PackageReference Include="Feliz" Version="3.3.3" />
  </ItemGroup>

</Project>
